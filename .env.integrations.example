# Optional isolated worker-service checks.
# Do not put production credentials here.

# FreeLLMAPI local/isolated service.
FREELLMAPI_BASE_URL=http://localhost:3001/v1
FREELLMAPI_API_KEY=freellmapi-your-isolated-unified-key
FREELLMAPI_MODEL=auto

# MagickAI real SDK command bridge.
MAGICKAI_REPO_PATH=../_readonly_references/magick_ai
MAGICKAI_WORKER_COMMAND=python workers/magickai_worker_bridge.py
MAGICKAI_MODEL=gpt-4o

# Required by MagickAI.from_env() when using the real SDK.
MONGO_URI=mongodb://localhost:27017
LITELLM_API_KEY=replace-with-isolated-test-key
LITELLM_BASE_URL=http://localhost:4000
